QToolBar,
QWidget#resultToolBar {
  background: transparent;
  border: none;
}

/* Shared-ish MODE indicator look for native Qt labels */
QLabel#statusIndicator {
  color: #111111;
  background: rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(0, 0, 0, 0.10);
  border-radius: 4px;
  padding: 2px 6px;
  margin: 0px 6px;
  font-size: 12px;
}
