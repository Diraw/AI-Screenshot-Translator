QToolBar {
  background: transparent;
  border: none;
}

/* Shared-ish MODE indicator look for native Qt labels */
QLabel#statusIndicator {
  color: #e0e0e0;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 4px;
  padding: 2px 6px;
  margin: 0px 6px;
  font-size: 12px;
}
