    "card_border_color": "100,100,100",
    "use_card_border": false,

    "show_preview_card": false,
    "show_result_window": true,

    "debug_mode": false,
    "storage_path": "",

    "default_result_window_locked": false,
    "lock_behavior": 0,

    "prev_result_shortcut": "z",
    "next_result_shortcut": "x",
